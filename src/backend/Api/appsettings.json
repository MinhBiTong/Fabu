{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=DESKTOP-EFRRF7H\\MSSQLSERVER01;Database=fabu;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Auth": {
    "Enabled": true
  },
  "Jwt": {
    "Key": "FABU_API_SUPER_SECRET_KEY_2026",
    "Issuer": "FabuApiIssuer",
    "Audience": "FabuApiClient",
    "ExpiryMinutes": 60
  },
  "RedisConfiguration": {
    "Enabled": true,
    "ConnectionStrings": "127.0.0.1"
  },
  "MailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "Fabu",
    "Password": "11111111",
    "From": "minh.nb.2462@aptechlearning.edu.vn",
    "EnableSsl": true
  },
  "RateLimiting": {
    "PermitLimit": 5,
    "WindowInSeconds": 60,
    "QueueLimit": 10
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "FabuApi"
    },
    "Destructure": [ { "Name": "ToString" } ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Microsoft.EntityFrameworkCore.Database.Command' and @m like '%Executed DbCommand%'"
        }
      }
    ],
    "Audit": {
      "Enabled": true,
      "LogFilePath": "Logs/audit-.txt",
      "RollingInterval": "Day"
    }
  },

  "ReverseProxy": {
    "Enabled": true,
    "Routes": [
      {
        "RouteId": "fabu_route",
        "ClusterId": "fabu_cluster",
        "Match": {
          "Path": "/fabu/{**catch-all}",
          "Methods": [ "GET", "POST", "PUT", "DELETE" ],
          "Headers": [
            {
              "Name": "X-Forwarded-Host",
              "Values": [ "localhost:5000" ]
            }
          ],
          "Host": "localhost:5000"
        }
      }
    ],
    "Clusters": [
      {
        "ClusterId": "fabu_cluster",
        "Destinations": [
          {
            "DestinationId": "fabu_destination",
            "Address": "http://localhost:5000/"
          }
        ]
      }
    ]
  }
}